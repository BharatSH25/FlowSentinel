[
  {
    "family": "flowsentinel-engine",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
    "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/flowsentinelTaskRole",
    "containerDefinitions": [
      {
        "name": "flowsentinel-engine",
        "image": "<ECR_REPO>/flowsentinel-engine:<TAG>",
        "essential": true,
        "portMappings": [{ "containerPort": 8080, "protocol": "tcp" }],
        "environment": [
          { "name": "LISTEN_ADDR", "value": ":8080" },
          { "name": "REDIS_ADDR", "value": "<REDIS_ENDPOINT>:6379" },
          { "name": "RULES_REFRESH_SECONDS", "value": "30" }
        ],
        "secrets": [
          { "name": "POSTGRES_DSN", "valueFrom": "<SSM_OR_SECRETS_MANAGER_ARN_FOR_POSTGRES_DSN>" }
        ],
        "logConfiguration": {
          "logDriver": "awslogs",
          "options": {
            "awslogs-group": "/ecs/flowsentinel-engine",
            "awslogs-region": "<REGION>",
            "awslogs-stream-prefix": "ecs"
          }
        },
        "healthCheck": {
          "command": ["CMD-SHELL", "wget -qO- http://localhost:8080/health || exit 1"],
          "interval": 30,
          "timeout": 5,
          "retries": 3,
          "startPeriod": 10
        }
      }
    ]
  },
  {
    "family": "flowsentinel-admin",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
    "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/flowsentinelTaskRole",
    "containerDefinitions": [
      {
        "name": "flowsentinel-admin",
        "image": "<ECR_REPO>/flowsentinel-admin:<TAG>",
        "essential": true,
        "portMappings": [{ "containerPort": 8001, "protocol": "tcp" }],
        "secrets": [
          { "name": "DATABASE_URL", "valueFrom": "<SSM_OR_SECRETS_MANAGER_ARN_FOR_DATABASE_URL>" }
        ],
        "logConfiguration": {
          "logDriver": "awslogs",
          "options": {
            "awslogs-group": "/ecs/flowsentinel-admin",
            "awslogs-region": "<REGION>",
            "awslogs-stream-prefix": "ecs"
          }
        },
        "healthCheck": {
          "command": ["CMD-SHELL", "wget -qO- http://localhost:8001/health || exit 1"],
          "interval": 30,
          "timeout": 5,
          "retries": 3,
          "startPeriod": 10
        }
      }
    ]
  }
]

