{
  "uid": "flowsentinel",
  "title": "FlowSentinel",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate (allowed vs denied)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(flowsentinel_requests_total[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Latency (p50/p95/p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(flowsentinel_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(flowsentinel_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(flowsentinel_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "barchart",
      "title": "Top clients by request volume",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, sum(rate(flowsentinel_requests_total[5m])) by (client_id))",
          "legendFormat": "{{client_id}}"
        }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 }
    },
    {
      "type": "timeseries",
      "title": "Redis error rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(flowsentinel_redis_errors_total[5m])",
          "legendFormat": "errors/s"
        }
      ],
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 }
    }
  ],
  "time": { "from": "now-30m", "to": "now" }
}
